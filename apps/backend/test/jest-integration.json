{
  "moduleFileExtensions": ["js", "json", "ts"],
  "testEnvironment": "node",
  "testRegex": ".integration.spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "roots": ["<rootDir>/integration", "<rootDir>/../src"],
  "moduleNameMapper": {
    "^@repo/(.*)$": "<rootDir>/../../../packages/$1"
  }
}
