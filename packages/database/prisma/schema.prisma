// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  owner
  admin
  member
}

model User {
  id                String             @id
  name              String
  email             String
  emailVerified     Boolean            @default(false)
  image             String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  sessions          Session[]
  accounts          Account[]
  members           Member[]
  classMembers      ClassMember[]
  classGroupMembers ClassGroupMember[]
  invitations       Invitation[]

  assignments    StudentAssignment[] @relation("UserStudentAssignments")
  Notes          StudentNote[]       @relation("UserStudentNotes")
  githubAccounts GitHubAccount[]
  widgets        Widget[]

  @@unique([email])
  @@map("user")
}

model Session {
  id                   String   @id
  expiresAt            DateTime
  token                String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  ipAddress            String?
  userAgent            String?
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeOrganizationId String?

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Organization {
  id          String       @id
  name        String
  slug        String
  logo        String?
  createdAt   DateTime
  metadata    String?
  members     Member[]
  invitations Invitation[]
  courses     Course[]

  @@unique([slug])
  @@map("organization")
}

model Member {
  id             String       @id
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           Role         @default(member)
  createdAt      DateTime

  @@index([organizationId])
  @@index([userId])
  @@map("member")
}

model Invitation {
  id             String       @id
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  role           Role?
  status         String       @default("pending")
  expiresAt      DateTime
  createdAt      DateTime     @default(now())
  inviterId      String
  user           User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email])
  @@map("invitation")
}

model Course {
  id             String  @id @default(cuid())
  organizationId String
  slug           String
  name           String
  description    String?

  rootLessonNodeId String?     @unique
  rootLessonNode   LessonNode? @relation("CourseRoot", fields: [rootLessonNodeId], references: [id])

  organization Organization @relation(fields: [organizationId], references: [id])

  lessonNodes LessonNode[] @relation("CourseToLessons")

  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  classes Class[]

  @@unique([organizationId, slug])
  @@map("course")
}

model LessonNode {
  id    String @id @default(cuid())
  title String

  parentId String?
  parent   LessonNode?  @relation("Tree", fields: [parentId], references: [id])
  children LessonNode[] @relation("Tree")

  courseId String
  course   Course @relation("CourseToLessons", fields: [courseId], references: [id])

  rootOfCourse Course? @relation("CourseRoot")

  type    LessonNodeType
  content Json?

  order Int?

  classChildren           ClassLessonNode[]        @relation("NodeRoot")
  autoAssignmentSchedules AutoAssignmentSchedule[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
  @@map("lesson_node")
}

enum LessonNodeType {
  course
  module
  lesson
  homework
}

model Class {
  id   String @id @default(cuid())
  name String

  courseId String
  course   Course @relation(fields: [courseId], references: [id])

  members ClassMember[]

  classLessonNodes        ClassLessonNode[]        @relation("ClassLessonNode")
  groups                  ClassGroup[]
  autoAssignmentSchedules AutoAssignmentSchedule[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("class")
}

model ClassMember {
  id String @id @default(cuid())

  classId String
  class   Class  @relation(fields: [classId], references: [id])

  role ClassRole

  userId String
  user   User   @relation(fields: [userId], references: [id])

  joinedAt DateTime @default(now())

  @@unique([classId, userId])
  @@map("class_member")
}

enum ClassRole {
  owner
  teacher
  student
}

enum AssignmentSource {
  teacher
  system
}

enum ScheduleIntervalUnit {
  minute
  hour
  day
}

model ClassGroup {
  id                String             @id @default(cuid())
  name              String
  description       String?
  classId           String
  class             Class              @relation(fields: [classId], references: [id], onDelete: Cascade)
  classGroupMembers ClassGroupMember[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@map("class_group")
}

model ClassGroupMember {
  id           String     @id @default(cuid())
  classGroupId String
  classGroup   ClassGroup @relation(fields: [classGroupId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation(fields: [userId], references: [id])
  joinedAt     DateTime   @default(now())

  @@unique([classGroupId, userId])
  @@map("class_group_member")
}

model ClassLessonNode {
  id String @id @default(cuid())

  classId String
  class   Class  @relation("ClassLessonNode", fields: [classId], references: [id])

  type    ClassAddonType
  content Json?

  lessonNodeId String
  lessonNode   LessonNode @relation("NodeRoot", fields: [lessonNodeId], references: [id])

  studentAssignment StudentAssignment[] @relation("StudentAssignments")
  notes             StudentNote[]       @relation("StudentNotes")

  createdAt DateTime @default(now())

  @@map("class_lesson_node")
}

model AutoAssignmentSchedule {
  id String @id @default(cuid())

  classId String
  class   Class  @relation(fields: [classId], references: [id], onDelete: Cascade)

  // Homework root node (LessonNodeType.homework)
  homeworkNodeId String
  homeworkNode   LessonNode @relation(fields: [homeworkNodeId], references: [id], onDelete: Cascade)

  createdBy String

  startAt DateTime

  intervalValue Int                  @default(2)
  intervalUnit  ScheduleIntervalUnit @default(day)

  // Window-based auto new assignment formula uses this multiplier
  decayFactor Float @default(0.5)
  minAutoNew  Int   @default(1)

  // Initial retry interval for pending/incorrect attempts
  initialReviewDelayMinutes Int @default(30)
  // Stop creating retries after this number of retries per student/root
  maxRetryPerRoot           Int @default(6)

  isActive      Boolean   @default(true)
  lastAutoRunAt DateTime?
  runCount      Int       @default(0)

  assignments StudentAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([classId, homeworkNodeId])
  @@index([isActive, startAt])
  @@map("auto_assignment_schedule")
}

enum ClassAddonType {
  lesson_note
  homework_imp
}

model StudentAssignment {
  id String @id @default(cuid())

  studentId String
  student   User   @relation("UserStudentAssignments", fields: [studentId], references: [id], onDelete: Cascade)

  assignmentId String
  assignment   ClassLessonNode @relation("StudentAssignments", fields: [assignmentId], references: [id], onDelete: Cascade)

  // Unified tracking for manual/quick/system assignment flows
  source AssignmentSource @default(teacher)

  scheduleId String?
  schedule   AutoAssignmentSchedule? @relation(fields: [scheduleId], references: [id], onDelete: SetNull)

  // Keep the same root for retries of a logical assignment thread
  rootAssignmentId String?

  // Scheduler uses this to determine when to generate next retry assignment
  reviewDueAt DateTime?

  // First attempt is immutable and remains the source for quality/retry logic.
  submissionData Json?

  // First-attempt submission timestamp.
  submittedAt DateTime?

  // Latest attempt snapshot for student review UX.
  latestSubmissionData Json?
  latestSubmittedAt    DateTime?

  // Aggregated attempt stats for quick reads.
  attemptCount        Int @default(0)
  correctAttemptCount Int @default(0)

  attempts StudentAssignmentAttempt[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, assignmentId])
  @@index([studentId])
  @@index([assignmentId])
  @@index([scheduleId, source, reviewDueAt])
  @@index([studentId, rootAssignmentId])
  @@map("student_assignment")
}

model StudentAssignmentAttempt {
  id String @id @default(cuid())

  studentAssignmentId String
  studentAssignment   StudentAssignment @relation(fields: [studentAssignmentId], references: [id], onDelete: Cascade)

  attemptNumber  Int
  submissionData Json
  isCorrect      Boolean
  submittedAt    DateTime @default(now())
  createdAt      DateTime @default(now())

  @@unique([studentAssignmentId, attemptNumber])
  @@index([studentAssignmentId, submittedAt])
  @@map("student_assignment_attempt")
}

model StudentNote {
  id String @id @default(cuid())

  studentId String
  student   User   @relation("UserStudentNotes", fields: [studentId], references: [id], onDelete: Cascade)

  noteId String
  note   ClassLessonNode @relation("StudentNotes", fields: [noteId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, noteId])
  @@index([studentId])
  @@index([noteId])
  @@map("student_note")
}

model GitHubAccount {
  id                String    @id @default(cuid())
  userId            String
  installationId    String    @unique // GitHub App Installation ID
  accountLogin      String // GitHub username or org name
  accountType       String // "User" or "Organization"
  accessToken       String? // Encrypted token
  accessTokenExpiry DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("github_account")
}

model Widget {
  id           String   @id @default(cuid())
  userId       String
  name         String
  repoFullName String
  repoUrl      String
  branch       String   @default("main")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  builds WidgetBuild[]

  @@index([userId])
  @@map("widget")
}

model WidgetBuild {
  id           String  @id @default(cuid())
  widgetId     String
  version      Int
  status       String  @default("pending")
  buildRunId   String?
  errorMessage String?

  startedAt   DateTime?
  completedAt DateTime?
  duration    Int? // Duration in seconds

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  widget Widget @relation(fields: [widgetId], references: [id], onDelete: Cascade)

  @@unique([widgetId, version])
  @@index([widgetId])
  @@index([status])
  @@map("widget_build")
}
